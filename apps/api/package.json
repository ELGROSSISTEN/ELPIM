{
  "name": "@epim/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx --watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@epim/crypto": "workspace:*",
    "@epim/db": "workspace:*",
    "prisma": "^6.2.1",
    "@epim/shared": "workspace:*",
    "@epim/shopify": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^9.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.34.5",
    "fastify": "^5.2.1",
    "fastify-raw-body": "^5.0.0",
    "ioredis": "^5.4.2",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
