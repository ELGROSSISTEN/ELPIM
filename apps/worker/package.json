{
  "name": "@epim/worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx --watch --env-file=.env src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/worker.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@epim/crypto": "workspace:*",
    "@epim/db": "workspace:*",
    "@epim/shared": "workspace:*",
    "@epim/shopify": "workspace:*",
    "bullmq": "^5.34.5",
    "ioredis": "^5.4.2",
    "pino": "^9.6.0",
    "saxes": "^6.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
