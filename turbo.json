{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": ["coverage/**"],
      "passThroughEnv": [
        "DATABASE_URL",
        "REDIS_URL",
        "JWT_SECRET",
        "MASTER_ENCRYPTION_KEY",
        "SHOPIFY_WEBHOOK_SECRET",
        "SHOPIFY_WEBHOOK_CALLBACK_BASE_URL",
        "NEXT_PUBLIC_API_URL"
      ]
    }
  }
}
